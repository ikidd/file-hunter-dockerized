# Image to run (default: GHCR image from this repo)
FILEHUNTER_IMAGE=ghcr.io/ikidd/file-hunter-dockerized:latest

# Data directory (bind mount) — database and app data persist here
FILEHUNTER_DATA=./data

# Host port to publish (container always listens on 8000)
FILEHUNTER_PORT=8000

# Full host filesystem access: mount host at /host in container (read-only).
# Set to / to enable (default). Leave empty to disable (mounts /tmp at /host only).
FILEHUNTER_MOUNT_HOST=1
FILEHUNTER_HOST_PATH=/

# Optional: set to 1 to seed demo data on first run
# FILE_HUNTER_DEMO=1

# Optional: mount additional host paths — add under volumes in docker-compose.yml, e.g.:
# - /media/drives:/locations:ro
# Then add location /locations/backup-disk in the UI
